include <stdio.h>
int main() {
    float m1, m2, m3, m4, m5, sum, percent;
    printf("Enter marks of 5 subjects: ");
    scanf("%f%f%f%f%f", &m1, &m2, &m3, &m4, &m5);

    sum = m1 + m2 + m3 + m4 + m5;
    percent = sum / 5;

    printf("Sum = %.2f\nPercentage = %.2f%%", sum, percent);
    return 0;
}
