#include <stdio.h>
int main() {
    float m1, m2, m3, m4, m5, percent;
    printf("Enter marks of 5 subjects: ");
    scanf("%f%f%f%f%f", &m1, &m2, &m3, &m4, &m5);

    percent = (m1 + m2 + m3 + m4 + m5) / 5;

    printf("Percentage = %.2f\n", percent);

    if(percent >= 90)
        printf("Grade: A");
    else if(percent >= 75)
        printf("Grade: B");
    else if(percent >= 60)
        printf("Grade: C");
    else if(percent >= 50)
        printf("Grade: D");
    else
        printf("Grade: F");

    return 0;
}
